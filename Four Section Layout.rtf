<!DOCTYPE html>\
<html>\
<head>\
    <title>Four Section Layout</title>\
\
    <style>\
        body \{\
            margin: 0;\
        \}\
\
        .container \{\
            display: flex;\
            flex-wrap: wrap;\
            height: 100vh;\
        \}\
\
        .box \{\
            width: 50%;\
            height: 50%;\
            text-align: center;\
            color: white;\
        \}\
\
        .box1 \{ background-color: red; \}\
        .box2 \{ background-color: blue; \}\
        .box3 \{ background-color: green; \}\
        .box4 \{ background-color: orange; \}\
    </style>\
</head>\
\
<body>\
\
<div class="container">\
    <div class="box box1"><h1>Section 1</h1></div>\
    <div class="box box2"><h1>Section 2</h1></div>\
    <div class="box box3"><h1>Section 3</h1></div>\
    <div class="box box4"><h1>Section 4</h1></div>\
</div>\
\
</body>\
</html>}
